# En-têtes de SÉCURITÉ (toutes les pages). CSP : au build, patch-pwa.mjs (durcirCsp)
# injecte dans le dist/_headers les hash sha256 des scripts inline du index.html final
# — les navigateurs modernes ignorent alors 'unsafe-inline' (gardé en repli pour les
# très vieux navigateurs) et n'exécutent QUE les scripts hachés. style-src garde
# 'unsafe-inline' (styles inline de react-native-web). img-src autorise les
# photos AN (fallback) + le self-hosting ; connect-src autorise l'envoi d'événements
# analytics + l'API Géo officielle (geo.api.gouv.fr) pour « Trouver mon député » par
# commune/code postal. frame-ancestors 'none' = pas d'iframe (anti-clickjacking).
# 'wasm-unsafe-eval' : la recherche sémantique compile du WebAssembly (onnxruntime-web,
# modèle e5-small AUTO-HÉBERGÉ). Directive étroite (autorise UNIQUEMENT la compilation
# WASM, aucune origine externe, pas d'eval JS arbitraire). ⚠️ Invisible en dev (CSP
# appliquée seulement par Cloudflare en prod) → à vérifier au déploiement.
/*
  Strict-Transport-Security: max-age=15552000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; img-src 'self' https://www2.assemblee-nationale.fr data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; connect-src 'self' https://data.scrutoir.fr https://scrutoir-data.pages.dev https://scrutoir-analytics.anthony-627.workers.dev https://geo.api.gouv.fr; font-src 'self' data:; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

# En-têtes de cache Cloudflare Pages (1ère visite + visiteurs non-PWA ; le SW gère
# les visites répétées en PWA). Règle plus spécifique en dernier = elle l'emporte.
# ⚠️ Les données /data/** sont servies par le projet Pages DÉDIÉ « scrutoir-data »
# (data.scrutoir.fr, cf. app/data-project/_headers) — plus aucun fichier /data ici.

# Bundle JS/CSS au nom hashé : immuable.
/_expo/static/*
  Cache-Control: public, max-age=31536000, immutable

# Icônes PWA (stables, mais pas hashées) : une semaine.
/icons/*
  Cache-Control: public, max-age=604800

# Coquille + métadonnées PWA : toujours revalider pour capter les déploiements.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/sw.js
  Cache-Control: no-cache
/manifest.json
  Cache-Control: no-cache
