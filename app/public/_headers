# En-têtes de SÉCURITÉ (toutes les pages). CSP pragmatique : 'unsafe-inline' nécessaire
# pour le bundle Expo + react-native-web (styles/scripts inline). img-src autorise les
# photos AN (fallback) + le self-hosting ; connect-src autorise l'envoi d'événements
# analytics. frame-ancestors 'none' = pas d'iframe (anti-clickjacking).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; img-src 'self' https://www2.assemblee-nationale.fr data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' https://scrutoir-analytics.anthony-627.workers.dev; font-src 'self' data:; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

# En-têtes de cache Cloudflare Pages (1ère visite + visiteurs non-PWA ; le SW gère
# les visites répétées en PWA). Règle plus spécifique en dernier = elle l'emporte.

# Données mutables (index, depute/*, parti/*, categories) : toujours revalider.
/data/*
  Cache-Control: public, max-age=0, must-revalidate

# Détail des scrutins : immuable une fois publié.
/data/scrutin/*
  Cache-Control: public, max-age=31536000, immutable

# version.json : jamais en cache (sert à détecter un nouveau déploiement).
/data/version.json
  Cache-Control: no-cache

# Bundle JS/CSS au nom hashé : immuable.
/_expo/static/*
  Cache-Control: public, max-age=31536000, immutable

# Icônes PWA (stables, mais pas hashées) : une semaine.
/icons/*
  Cache-Control: public, max-age=604800

# Coquille + métadonnées PWA : toujours revalider pour capter les déploiements.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/sw.js
  Cache-Control: no-cache
/manifest.json
  Cache-Control: no-cache
