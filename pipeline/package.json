{
  "name": "votes-an-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pipeline d'ingestion des donnees Open Data de l'Assemblee Nationale (deputes, scrutins, classification thematique).",
  "scripts": {
    "ingest": "tsx src/ingest.ts",
    "ingest:download": "tsx src/ingest.ts --download",
    "ingest:refresh": "tsx src/ingest.ts --refresh",
    "classify": "tsx src/classify.ts",
    "classify:ia": "tsx src/classifyIA.ts",
    "detect-questions": "tsx src/detecteurQuestions.ts",
    "build-test-data": "tsx src/buildTestData.ts",
    "test": "tsx --test src/stats.test.ts ../app/src/testProximite/score.test.ts ../app/src/search/deterministe.test.ts ../app/src/search/fusion.test.ts",
    "test-stats": "tsx --test src/stats.test.ts",
    "test-score": "tsx --test ../app/src/testProximite/score.test.ts",
    "test-search": "tsx --test ../app/src/search/deterministe.test.ts ../app/src/search/fusion.test.ts",
    "test-semantic": "tsx --test ../app/src/search/semantic.test.ts",
    "export:static": "tsx src/exportStatic.ts",
    "embeddings": "tsx src/embeddings.ts",
    "link-amendements": "tsx src/linkAmendements.ts",
    "query": "tsx src/query.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@huggingface/transformers": "^4.2.0",
    "better-sqlite3": "^11.8.1",
    "node-stream-zip": "^1.15.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "AGPL-3.0-only"
}
